# ============================================
# Socket.IO & Realtime Features Configuration
# ============================================

# Socket.IO Server Port (used by server.ts)
PORT=3001

# Client URL that connects to the WebSocket server
# Used by Socket.IO server's CORS configuration
CLIENT_URL=http://localhost:3000

# Public WebSocket server URL (visible to client)
# This is what the frontend will use to connect
NEXT_PUBLIC_WS_URL=http://localhost:3001

# ============================================
# Email & Third-party Services
# ============================================

# Resend API key for the contact form
RESEND_API_KEY=re_Bn1mHZCH_HtKrSySmw4UiyoZE6fuWkmAR

# Umami Analytics (optional)
UMAMI_DOMAIN=
UMAMI_SITE_ID=

# ============================================
# Production Configuration Example
# ============================================
# For production, update these values:
# CLIENT_URL=https://yourdomain.com
# NEXT_PUBLIC_WS_URL=https://yourdomain.com
# (Make sure your WebSocket endpoint is properly proxied or served from the same domain)
